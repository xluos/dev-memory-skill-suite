{
  "name": "@xluos/dev-assets-cli",
  "version": "0.12.1",
  "description": "CLI for dev-assets hooks and repo-local setup",
  "license": "MIT",
  "scripts": {
    "check": "node scripts/npm/check-package.mjs",
    "build": "node scripts/npm/build-package.mjs",
    "pack:dry-run": "npm pack --dry-run",
    "publish:dry-run": "npm publish --access public --registry https://registry.npmjs.org --dry-run",
    "publish:npm": "npm publish --access public --registry https://registry.npmjs.org",
    "prepublishOnly": "npm run check"
  },
  "bin": {
    "dev-assets": "bin/dev-assets.js"
  },
  "files": [
    "bin/dev-assets.js",
    "hooks/*.json",
    "hooks/README.md",
    "lib/*.py",
    "lib/ui-server.js",
    "lib/ui-app.html",
    "lib/assets/*",
    "scripts/hooks/_common.py",
    "scripts/hooks/session_start.py",
    "scripts/hooks/pre_compact.py",
    "scripts/hooks/stop.py",
    "scripts/hooks/session_end.py",
    "suite-manifest.json",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  }
}
