flowchart TB
  CODEX[~/.codex/sessions/<br/>rollout JSONL]
  SCAN[~/.dev-memory/jobs/<br/>session-scan/<br/>state / sessions / runs / logs]
  ROOT[~/.dev-memory/repos/<br/>&lt;repo-key&gt;/]
  REPO[repo/<br/>跨分支共享层]
  BRANCHES[branches/]
  ACTIVE[&lt;branch-key&gt;/<br/>当前分支层]
  ARCHIVE[_archived/<br/>已归档分支]

  ROOT --> REPO
  CODEX --> SCAN
  SCAN --> ROOT
  ROOT --> BRANCHES
  BRANCHES --> ACTIVE
  BRANCHES --> ARCHIVE

  REPO --> RM[manifest.json]
  REPO --> RO[overview.md]
  REPO --> RD[decisions.md]
  REPO --> RG[glossary.md]
  REPO --> RL[log.md]
  REPO --> RA[artifacts/]

  ACTIVE --> BM[manifest.json]
  ACTIVE --> BO[overview.md]
  ACTIVE --> BP[progress.md<br/>Git 派生导航与 filemap]
  ACTIVE --> BD[decisions.md]
  ACTIVE --> BR[risks.md]
  ACTIVE --> BG[glossary.md]
  ACTIVE --> BU[unsorted.md]
  ACTIVE --> BPP[pending-promotion.md]
  ACTIVE --> BL[log.md]
  ACTIVE --> BA[artifacts/history/]

  classDef root fill:#1e293b,stroke:#1e293b,color:#ffffff
  classDef repo fill:#cffafe,stroke:#0891b2,color:#083344
  classDef branch fill:#dcfce7,stroke:#16a34a,color:#052e16
  classDef archive fill:#e2e8f0,stroke:#64748b,color:#0f172a
  classDef file fill:#ffffff,stroke:#94a3b8,color:#0f172a
  class ROOT,CODEX root
  class SCAN repo
  class REPO repo
  class BRANCHES,ACTIVE branch
  class ARCHIVE archive
  class RM,RO,RD,RG,RL,RA,BM,BO,BP,BD,BR,BG,BU,BPP,BL,BA file
